APP_DISTRIBUTION_MODE=portable
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
LOCAL_ONLY_ENFORCED=true
ENABLE_DOCS=false
ENABLE_OPENAPI=false
WORKER_PROFILE=desktop_light
# Offline troubleshooting can set WORKER_PROFILE=none/off/disabled to stop all workers.
MARKET_EVENTS_TRANSLATE_ENABLED=false
MARKET_EVENTS_TRANSLATION_WORKER_ENABLED=false
DATABASE_URL=sqlite+aiosqlite:///runtime/data/trading_system.db
JWT_SECRET_KEY=replace-me-with-generated-secret
BOOTSTRAP_ADMIN_USERNAME=localadmin
BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-generated-password
LOCAL_AUTO_BOOTSTRAP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ALL_INSTRUMENTS=true
LOCAL_BOOTSTRAP_CANDLE_LIMIT=240
LOCAL_BOOTSTRAP_WARMUP_TIMEFRAMES=["1h","4h","1d","1w","30d"]
LOCAL_BOOTSTRAP_STRUCTURE_TIMEFRAMES=["1h","4h","1d","1w"]

# Optional API keys. Leave blank when unavailable; the UI will show "not configured".
FRED_API_KEY=
BLS_API_KEY=
BEA_API_KEY=
GATEIO_API_KEY=
GATEIO_API_SECRET=
COINMARKETCAP_API_KEY=
ALPHA_VANTAGE_API_KEY=
NASDAQ_DATA_LINK_API_KEY=
OPENEXCHANGERATES_APP_ID=
TUSHARE_TOKEN=
ZHITUAPI_TOKEN=
AGUSHUJU_API_KEY=
AGUSHUJU_API_BASE_URL=
TWELVEDATA_API_KEY=
TIINGO_API_KEY=

# A-share ETF quotes. Eastmoney direct quote API does not require an API key.
ASHARE_ETF_PROVIDER_ORDER=["eastmoney_direct"]
ASHARE_ETF_QUOTE_TTL_SECONDS=15
ASHARE_ETF_STALE_CACHE_SECONDS=1800
ASHARE_ETF_TIMEOUT_SECONDS=6
ASHARE_ETF_EASTMONEY_BASE_URL=https://push2.eastmoney.com
