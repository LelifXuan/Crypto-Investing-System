APP_DISTRIBUTION_MODE=portable
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=false
LOCAL_ONLY_ENFORCED=true
ENABLE_DOCS=false
ENABLE_OPENAPI=false
WORKER_PROFILE=desktop_light
# 离线或排查启动问题时可改为 none/off/disabled，所有 worker 都不会启动。
MARKET_EVENTS_TRANSLATE_ENABLED=false
MARKET_EVENTS_TRANSLATION_WORKER_ENABLED=false
DATABASE_URL=sqlite+aiosqlite:///runtime/data/trading_system.db
JWT_SECRET_KEY=replace-me-with-generated-secret
BOOTSTRAP_ADMIN_USERNAME=localadmin
BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-generated-password
LOCAL_AUTO_BOOTSTRAP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ALL_INSTRUMENTS=true
LOCAL_BOOTSTRAP_CANDLE_LIMIT=240
LOCAL_BOOTSTRAP_WARMUP_TIMEFRAMES=["1h","4h","1d","1w","30d"]
LOCAL_BOOTSTRAP_STRUCTURE_TIMEFRAMES=["1h","4h","1d","1w"]
