APP_NAME=Trading System API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///data/trading_system.db
DEFAULT_REPORTING_CURRENCY=USD
DEFAULT_COST_METHOD=AVG_COST
CORS_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]

SINGLE_USER_MODE=true
LOCAL_ONLY_ENFORCED=true
LOCAL_ALLOWED_HOSTS=["127.0.0.1","::1","localhost","testclient"]
LOCAL_TENANT_ID=local_tenant
LOCAL_USER_ID=local_user
LOCAL_USERNAME=local
LOCAL_USER_ROLES=["admin","trader","analyst","viewer"]

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
LOCAL_AUTO_BOOTSTRAP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ALL_INSTRUMENTS=false
LOCAL_BOOTSTRAP_CANDLE_LIMIT=240
LOCAL_BOOTSTRAP_WARMUP_TIMEFRAMES=["1h","4h","1d"]
LOCAL_BOOTSTRAP_STRUCTURE_TIMEFRAMES=["1h","4h","1d"]
WORKER_PROFILE=desktop_light
# 本地离线排障可设置 WORKER_PROFILE=none/off/disabled，页面仍会读取本地快照与降级状态。

EVENT_BUS_ENABLED=true
EVENT_BUS_POLL_INTERVAL_MS=1500
EVENT_BUS_BATCH_SIZE=25
EVENT_BUS_MAX_RETRIES=5
EVENT_BUS_RETRY_DELAY_SECONDS=10

REQUIRE_IDEMPOTENCY_FOR_FILL_WRITES=true

MARKET_DATA_PROVIDER=gateio
MARKET_DATA_PREFER_LIVE=true
GATEIO_BASE_URL=https://api.gateio.ws/api/v4
GATEIO_TIMEOUT_SECONDS=10
GATEIO_DEFAULT_SETTLE=usdt
MARKET_STREAM_ENABLED=true
MARKET_STREAM_PREFER_WS_CACHE=true
MARKET_STREAM_PERSIST_MARKS=true
MARKET_STREAM_PERSIST_CANDLES=true
MARKET_STREAM_TIMEFRAMES=["1m","5m"]
MARKET_STREAM_PING_INTERVAL_SECONDS=20
MARKET_STREAM_RECONNECT_DELAY_SECONDS=5
MARKET_STREAM_MARK_PERSIST_MIN_INTERVAL_SECONDS=3
GATEIO_SPOT_WS_URL=wss://api.gateio.ws/ws/v4/
GATEIO_FUTURES_WS_URL_TEMPLATE=wss://fx-ws.gateio.ws/v4/ws/{settle}

# ── Translation ──
MARKET_EVENTS_TRANSLATE_ENABLED=true
MARKET_EVENTS_TRANSLATION_PROVIDER=mymemory
MARKET_EVENTS_TRANSLATION_BASE_URL=https://api.mymemory.translated.net/get
MARKET_EVENTS_TRANSLATION_TARGET_LANG=zh-CN
MARKET_EVENTS_TRANSLATION_TIMEOUT_SECONDS=10
PORTABLE_REMOTE_TRANSLATION_ENABLED=false

# ── Precompute ──
PRECOMPUTE_ENABLED=true
PRECOMPUTE_MAX_QUEUE_SIZE=300
PRECOMPUTE_WORKER_INTERVAL_SECONDS=3
PRECOMPUTE_MAX_CONCURRENCY=2
PRECOMPUTE_CPU_IDLE_THRESHOLD=0.8
PRECOMPUTE_MIN_SECONDS_BETWEEN_SAME_KEY=120

# ── Monitoring ──
MONITORING_SCHEDULER_ENABLED=true
MONITORING_SCHEDULER_POLL_SECONDS=15
MONITORING_STALE_REFRESH_CHECK_SECONDS=1800
MONITORING_DEFAULT_QUALITY_SCORE=75
MONITORING_DEMO_QUALITY_SCORE=60

# ── Page Cache TTLs (seconds) ──
PAGE_SNAPSHOT_ANALYSIS_TTL_SECONDS=300
PAGE_SNAPSHOT_STRUCTURE_TTL_SECONDS=300
PAGE_SNAPSHOT_ALERTS_TTL_SECONDS=300
PAGE_SNAPSHOT_MONITORING_TTL_SECONDS=600
PAGE_SNAPSHOT_MACRO_TTL_SECONDS=600
PAGE_SNAPSHOT_EVENTS_TTL_SECONDS=300

# ── Macro Data ──
FRED_PUBLIC_CSV_URL=https://fred.stlouisfed.org/graph/fredgraph.csv
GLASSNODE_API_KEY=
SHARED_QUERY_CACHE_SECONDS=60
MACRO_CALENDAR_CACHE_SECONDS=3600

# ── Other ──
INDICATOR_READ_AUTO_REFRESH=false
INDICATOR_REFRESH_INTERVAL_SECONDS=300
LOCAL_BOOTSTRAP_CANDLE_LIMITS_BY_TIMEFRAME={"1h":1000,"4h":1000,"1d":1000,"1w":520,"30d":360}
