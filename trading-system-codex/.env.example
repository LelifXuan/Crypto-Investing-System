APP_NAME=Trading System API
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./trading_system.db
DEFAULT_REPORTING_CURRENCY=USD
DEFAULT_COST_METHOD=AVG_COST
CORS_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]

SINGLE_USER_MODE=true
LOCAL_ONLY_ENFORCED=true
LOCAL_ALLOWED_HOSTS=["127.0.0.1","::1","localhost","testclient"]
LOCAL_TENANT_ID=local_tenant
LOCAL_USER_ID=local_user
LOCAL_USERNAME=local
LOCAL_USER_ROLES=["admin","trader","analyst","viewer"]

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120

BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
LOCAL_AUTO_BOOTSTRAP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ENABLED=true
LOCAL_BOOTSTRAP_WARMUP_ALL_INSTRUMENTS=true
LOCAL_BOOTSTRAP_CANDLE_LIMIT=240
LOCAL_BOOTSTRAP_WARMUP_TIMEFRAMES=["1h","4h","1d","1w","30d"]
LOCAL_BOOTSTRAP_STRUCTURE_TIMEFRAMES=["1h","4h","1d","1w"]
WORKER_PROFILE=desktop_light
# 本地离线排障可设置 WORKER_PROFILE=none/off/disabled，页面仍会读取本地快照与降级状态。

EVENT_BUS_ENABLED=true
EVENT_BUS_POLL_INTERVAL_MS=1500
EVENT_BUS_BATCH_SIZE=25
EVENT_BUS_MAX_RETRIES=5
EVENT_BUS_RETRY_DELAY_SECONDS=10

REQUIRE_IDEMPOTENCY_FOR_FILL_WRITES=true

MARKET_DATA_PROVIDER=gateio
MARKET_DATA_PREFER_LIVE=true
GATEIO_BASE_URL=https://api.gateio.ws/api/v4
GATEIO_TIMEOUT_SECONDS=10
GATEIO_DEFAULT_SETTLE=usdt
MARKET_STREAM_ENABLED=true
MARKET_STREAM_PREFER_WS_CACHE=true
MARKET_STREAM_PERSIST_MARKS=true
MARKET_STREAM_PERSIST_CANDLES=true
MARKET_STREAM_TIMEFRAMES=["1m","5m"]
MARKET_STREAM_PING_INTERVAL_SECONDS=20
MARKET_STREAM_RECONNECT_DELAY_SECONDS=5
MARKET_STREAM_MARK_PERSIST_MIN_INTERVAL_SECONDS=3
GATEIO_SPOT_WS_URL=wss://api.gateio.ws/ws/v4/
GATEIO_FUTURES_WS_URL_TEMPLATE=wss://fx-ws.gateio.ws/v4/ws/{settle}
