{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/event-envelope.schema.json",
  "title": "EventEnvelope",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "source",
    "partition_key",
    "ts_event",
    "ts_ingest",
    "payload"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string" },
    "schema_version": { "type": "integer" },
    "source": { "type": "string" },
    "partition_key": { "type": "string" },
    "idempotency_key": { "type": ["string", "null"] },
    "ts_event": { "type": "integer" },
    "ts_ingest": { "type": "integer" },
    "trace": {
      "type": "object",
      "properties": {
        "trace_id": { "type": "string" },
        "span_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
